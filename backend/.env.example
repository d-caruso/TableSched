# Copy to .env (dev) or .env.prod (production) and fill in values.
# Never commit files with real credentials.

DJANGO_SECRET_KEY=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
STRIPE_API_KEY=sk_
STRIPE_WEBHOOK_SECRET=we_
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Single API domain — no wildcard subdomain needed with path-based routing.
# Example: api.tablesched.domenicocaruso.com or tablesched.hf.space
ALLOWED_HOSTS=

PUBLIC_DOMAIN=

# Tenant API URLs follow the pattern: <ALLOWED_HOSTS>/restaurants/<schema>/api/v1/
# Example: tablesched.hf.space/restaurants/new-york/api/v1/bookings/

# PUBLIC_BOOKING_BASE_URL points to the FRONTEND (not the API).
# Used to build tokenized booking links sent to customers via SMS/email.
# Example: https://tablesched.domenicocaruso.com
PUBLIC_BOOKING_RETURN_URL=
PUBLIC_BOOKING_CANCEL_URL=
PUBLIC_BOOKING_BASE_URL=

# If true, the root shosw a simple directory page listing all active tenants with their links
EXPO_PUBLIC_SHOW_TENANT_DIRECTORY=true
